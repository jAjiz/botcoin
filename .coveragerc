[run]
source =
    core
    exchange
    services
    trading
omit =
    # Standalone backtesting script; no runtime business logic to unit test
    trading/backtest.py
    # Parameter optimisation script; runs offline and has no unit-testable logic
    trading/optimize_params.py
    # Thread-safe shared-state wrapper; behaviour is threading I/O with no business logic
    core/runtime.py
    # Telegram service package; covered in commit 14 (test(api,telegram))
    services/telegram/*
    # Top-level session orchestrator; end-to-end coverage is handled by integration tests
    core/scheduler.py