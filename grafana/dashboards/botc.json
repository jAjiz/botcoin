{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Market Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT to_timestamp(\"time\") AS time, pair AS metric, close FROM ohlc_data WHERE pair IN ($pair) AND $__timeFilter(to_timestamp(\"time\")) ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Close price",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT to_timestamp(\"time\") AS time, pair AS metric, atr FROM ohlc_data WHERE pair IN ($pair) AND $__timeFilter(to_timestamp(\"time\")) AND atr IS NOT NULL ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "ATR",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "unit": "currencyEUR" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 9 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "repeat": "pair",
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT close FROM ohlc_data WHERE pair = '$pair' ORDER BY \"time\" DESC LIMIT 1",
          "refId": "A"
        }
      ],
      "title": "Latest close — $pair",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101,
      "title": "Performance Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 15 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) FROM closed_positions WHERE $__timeFilter(closed_at)",
          "refId": "A"
        }
      ],
      "title": "Total closed positions",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 15 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(pnl_percent), 0) FROM closed_positions WHERE $__timeFilter(closed_at)",
          "refId": "A"
        }
      ],
      "title": "Cumulative PnL %",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 15 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT CASE WHEN SUM(CASE WHEN pnl_percent <= 0 THEN 1 ELSE 0 END) = 0 THEN NULL ELSE SUM(CASE WHEN pnl_percent > 0 THEN 1 ELSE 0 END)::float / SUM(CASE WHEN pnl_percent <= 0 THEN 1 ELSE 0 END)::float END FROM closed_positions WHERE $__timeFilter(closed_at)",
          "refId": "A"
        }
      ],
      "title": "Win/loss ratio",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "options": { "barWidth": 0.6, "fillOpacity": 80, "groupWidth": 0.7, "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT closed_at AS time, pair AS metric, pnl_percent FROM closed_positions WHERE $__timeFilter(closed_at) AND pair IN ($pair) ORDER BY closed_at",
          "refId": "A"
        }
      ],
      "title": "PnL per close",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT closed_at AS time, SUM(pnl_percent) OVER (ORDER BY closed_at) AS cumulative_pnl FROM closed_positions WHERE $__timeFilter(closed_at) ORDER BY closed_at",
          "refId": "A"
        }
      ],
      "title": "Cumulative PnL over time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "id": 9,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT pair, side, entry_price, activation_price, trailing_price, stop_price, updated_at FROM trailing_state WHERE closing_order_id IS NULL AND pair IN ($pair) ORDER BY pair",
          "refId": "A"
        }
      ],
      "title": "Open positions",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 102,
      "title": "System Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 121 },
              { "color": "red", "value": 301 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "id": 10,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT EXTRACT(EPOCH FROM (now() - MAX(ended_at))) FROM sessions WHERE status = 'completed'",
          "refId": "A"
        }
      ],
      "title": "Seconds since last successful session",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "text": "RUNNING" }, "1": { "color": "red", "text": "PAUSED" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 6, "y": 36 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT (control_value = 'true')::int FROM bot_control WHERE control_key = 'bot_paused'",
          "refId": "A"
        }
      ],
      "title": "Bot paused",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 36 },
      "id": 12,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', updated_at) AS time, pair AS metric, COUNT(*) AS rows FROM ohlc_data WHERE $__timeFilter(updated_at) AND pair IN ($pair) GROUP BY 1, pair ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "OHLC ingestion rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 103,
      "title": "Sessions",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "stacking": { "group": "A", "mode": "normal" } } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "id": 13,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', started_at) AS time, status AS metric, COUNT(*) AS sessions FROM sessions WHERE $__timeFilter(started_at) GROUP BY 1, status ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Sessions per hour by status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.20 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 45 },
      "id": 14,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(CASE WHEN status = 'failed' THEN 1 ELSE 0 END)::float / NULLIF(COUNT(*), 0), 0) FROM sessions WHERE started_at >= now() - interval '24 hours'",
          "refId": "A"
        }
      ],
      "title": "Session failure rate (last 24h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "id": 15,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT id, started_at, ended_at, status, EXTRACT(EPOCH FROM (ended_at - started_at)) AS duration_s, jsonb_array_length(COALESCE(log_messages, '[]'::jsonb)) AS log_count FROM sessions ORDER BY started_at DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Recent sessions",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "id": 16,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Ascending", "wrapLogMessage": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT (msg->>'ts')::timestamptz AS time, msg->>'level' AS level, msg->>'message' AS body FROM sessions, jsonb_array_elements(log_messages) AS msg WHERE id = (SELECT MAX(id) FROM sessions) ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Last session log",
      "type": "logs"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["botc", "trading"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "postgres", "uid": "botc-postgres" },
        "definition": "SELECT DISTINCT pair FROM ohlc_data ORDER BY 1",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "pair",
        "options": [],
        "query": "SELECT DISTINCT pair FROM ohlc_data ORDER BY 1",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Pair"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BoTC Overview",
  "uid": "botc-overview",
  "version": 1
}
