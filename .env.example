# ==============================
# Service URLs (set automatically by docker-compose; override for local dev)
# ==============================
API_BASE_URL=http://botc:8000
TELEGRAM_SERVICE_URL=http://telegram:8001

# ==============================
# Required credentials
# ==============================
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_API_SECRET=your_kraken_api_secret
TELEGRAM_ENABLED=true
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_USER_ID=your_telegram_user_id

# API_SECRET_TOKEN protects all REST endpoints and the /notify webhook.
# Both botc and telegram read this from the same .env.
# If unset, the app refuses to start unless ALLOW_NO_AUTH=true is also set.
API_SECRET_TOKEN=your_api_secret_token
# Explicit opt-in to run the API without authentication (development only).
ALLOW_NO_AUTH=false

# Kill switch for the optimizer endpoints. The optimizer is CPU/RAM-bound and
# can starve the trading engine on a low-resource host (e.g. a free-tier micro
# VM). Set to true there to reject new /optimizer/jobs with 503; run the
# optimizer offline on a bigger machine instead. Leave false to keep it enabled.
OPTIMIZER_DISABLED=false

# ==============================
# Database settings
# ==============================
POSTGRES_DB=DBbotc
POSTGRES_USER=botc
POSTGRES_PASSWORD=change_me_with_a_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ==============================
# Core bot settings
# ==============================
PAIRS=XBTEUR,ETHEUR
# Master trading switch. Leave true in production. Set to false to run a
# non-trading replica that still ingests OHLC, calibrates, records sessions and
# serves the API/optimizer but never opens or manages positions (e.g. a local
# stack used to run the optimizer with full features).
TRADING_ENABLED=true
SLEEPING_INTERVAL=60
PARAM_SESSIONS=720
CANDLE_TIMEFRAME=15
ATR_PERIOD=14
ATR_DESV_LIMIT=0.2
MIN_VALUE=10
TELEGRAM_POLL_INTERVAL=10
MINIMUM_CHANGE_PCT=0.02

# ==============================
# Pair allocation and behavior
# Use one block per pair listed in PAIRS
# ==============================
XBTEUR_TARGET_PCT=50
XBTEUR_HODL_PCT=25
XBTEUR_K_ACT=1.20
XBTEUR_MIN_MARGIN=0
XBTEUR_STOP_PCT_LL=0.90
XBTEUR_STOP_PCT_LV=0.90
XBTEUR_STOP_PCT_MV=0.90
XBTEUR_STOP_PCT_HV=0.90
XBTEUR_STOP_PCT_HH=0.90

ETHEUR_TARGET_PCT=50
ETHEUR_HODL_PCT=25
ETHEUR_K_ACT=1.20
ETHEUR_MIN_MARGIN=0
ETHEUR_STOP_PCT_LL=0.90
ETHEUR_STOP_PCT_LV=0.90
ETHEUR_STOP_PCT_MV=0.90
ETHEUR_STOP_PCT_HV=0.90
ETHEUR_STOP_PCT_HH=0.90

# ==============================
# Grafana
# ==============================
# Password for the read-only Postgres role used by Grafana panels.
# Consumed by both the Alembic migration (`grafana_reader` creation) and the
# grafana service's datasource provisioning.
GRAFANA_DB_PASSWORD=change_me_with_a_strong_password

# Admin login for the Grafana UI. First-boot only — Grafana stores the
# bcrypt'd password in its volume after that.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_with_a_strong_password
