{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "System Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "text": "RUNNING" }, "1": { "color": "red", "text": "PAUSED" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT (control_value = 'true')::int FROM bot_control WHERE control_key = 'bot_paused'",
          "refId": "A"
        }
      ],
      "title": "Bot paused",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": { "unit": "dateTimeAsLocal" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT MAX(ended_at) AS last_session FROM sessions WHERE status = 'completed'",
          "refId": "A"
        }
      ],
      "title": "Last successful session",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Market Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 6 },
      "id": 3,
      "options": {
        "mode": "candles",
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "colors": { "up": "green", "down": "red" },
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT to_timestamp(\"time\") AS time, open::float AS open, high::float AS high, low::float AS low, close::float AS close FROM ohlc_data WHERE pair = '$pair' AND $__unixEpochFilter(\"time\") ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Price",
      "type": "candlestick"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 6 },
      "id": 4,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT to_timestamp(\"time\") AS time, atr::float AS atr FROM ohlc_data WHERE pair = '$pair' AND $__unixEpochFilter(\"time\") AND atr IS NOT NULL ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "ATR",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT pair, side, entry_price, activation_price, trailing_price, stop_price, updated_at FROM trailing_state WHERE closing_order_id IS NULL AND pair = '$pair' ORDER BY pair",
          "refId": "A"
        }
      ],
      "title": "Open positions",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Performance Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 23 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS total FROM closed_positions WHERE pair = '$pair'",
          "refId": "A"
        }
      ],
      "title": "Total closed positions",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 23 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(CASE WHEN pnl_percent > 0 THEN 1.0 ELSE 0.0 END) / NULLIF(SUM(CASE WHEN pnl_percent <= 0 THEN 1.0 ELSE 0.0 END), 0), 0) AS win_loss_ratio FROM closed_positions WHERE pair = '$pair'",
          "refId": "A"
        }
      ],
      "title": "Win/loss ratio",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 23 },
      "id": 8,
      "options": { "barWidth": 0.6, "fillOpacity": 80, "groupWidth": 0.7, "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT closed_at AS time, pnl_percent FROM closed_positions WHERE pair = '$pair' ORDER BY closed_at",
          "refId": "A"
        }
      ],
      "title": "PnL per close",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "id": 9,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "time_series",
          "rawSql": "SELECT closed_at AS time, SUM(pnl_percent) OVER (ORDER BY closed_at) AS cumulative_pnl FROM closed_positions WHERE pair = '$pair' ORDER BY closed_at",
          "refId": "A"
        }
      ],
      "title": "Cumulative PnL over time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "title": "Sessions",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "id": 10,
      "options": { "barWidth": 0.6, "fillOpacity": 80, "groupWidth": 0.7, "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" }, "xField": "status" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT status, COUNT(*) AS sessions FROM sessions WHERE $__timeFilter(started_at) GROUP BY status ORDER BY status",
          "refId": "A"
        }
      ],
      "title": "Sessions by status",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 36 },
      "id": 11,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT id, started_at, ended_at, status, EXTRACT(EPOCH FROM (ended_at - started_at)) AS duration_s, CASE WHEN log_messages::text ILIKE '%Stop%' THEN 'close' WHEN log_messages::text ILIKE '%New%' THEN 'open' WHEN log_messages::text ILIKE '%Update%' OR log_messages::text ILIKE '%Recalibrate%' OR log_messages::text ILIKE '%Re-anchor%' THEN 'update' ELSE '-' END AS activity FROM sessions ORDER BY started_at DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Recent sessions",
      "type": "table"
    },
    {
      "datasource": { "type": "postgres", "uid": "botc-postgres" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "id": 12,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "botc-postgres" },
          "format": "table",
          "rawSql": "SELECT (msg->>'ts')::timestamptz AS time, msg->>'level' AS level, msg->>'message' AS message FROM sessions, jsonb_array_elements(log_messages) AS msg WHERE id = (SELECT MAX(id) FROM sessions) ORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Last session log",
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["botc", "trading"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "postgres", "uid": "botc-postgres" },
        "definition": "SELECT DISTINCT pair FROM ohlc_data ORDER BY 1",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "pair",
        "options": [],
        "query": "SELECT DISTINCT pair FROM ohlc_data ORDER BY 1",
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Pair"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BoTC Overview",
  "uid": "botc-overview",
  "version": 1
}
